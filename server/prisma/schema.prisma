generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          Int      @id @default(autoincrement())
  project     String
  Energy_kwh  Float
  Price       Float
  Nro_panels  Int
  status      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}